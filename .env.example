# ─────────────────────────────────────────────────────────────
#  Plantilla de variables de entorno (Módulo 7.3).
#  NO pongas valores reales aquí. Copia a .env (ignorado por git) y rellena.
# ─────────────────────────────────────────────────────────────

# SQL Server — el pool DEBE estar acotado (Módulo 6: presupuesto de RAM). Usa el DNS
# canónico (dbo.MotorBaseDatos.HostDefault en Aba/database/scripts/002), no una IP fija,
# para que rotar el host/IP del VPS nunca exija tocar este archivo (dinámico).
SA_PASSWORD=
DB_CONNECTION_STRING=Server=db.aba.andrescortes.dev,1433;Database=ABA_Control;User Id=sa;Password=;TrustServerCertificate=True;Max Pool Size=20;Min Pool Size=2;Connect Timeout=15;

# JWT — la clave debe tener al menos 32 caracteres (256 bits)
JWT_KEY=
JWT_ISSUER=abaproblem-api
JWT_AUDIENCE=abaproblem-clients

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend (origen exacto para CORS y redirección post-login)
FRONTEND_BASE_URL=https://aba.andrescortes.dev

# Red Docker desde la que se confía el header X-Forwarded-For. Módulo 5.3 — nunca
# confiar en X-Forwarded-For sin acotar origen. Verifica la subnet REAL en el VPS con
# `docker network inspect bridge | grep Subnet` — no asumas el valor de abajo.
REVERSE_PROXY_TRUSTED_NETWORK=172.17.0.0/16

# MySQL — mismo host que SQL Server (dbo.MotorBaseDatos.HostDefault ya usa
# db.aba.andrescortes.dev para ambos motores). La cuenta admin debe tener SOLO:
# CREATE, DROP, CREATE USER, GRANT OPTION, SELECT ON information_schema.*
# — NUNCA SUPER ni ALL PRIVILEGES ON *.*.
MYSQL_ADMIN_CONNECTION_STRING=Server=db.aba.andrescortes.dev;Port=3306;Uid=aba_provisioner;Pwd=;

# Cloudflare Turnstile (control 1.3 — captcha condicional tras 3 fallos de login).
# SiteKey es pública (la usa el frontend); SecretKey es PRIVADA, solo el backend.
# https://dash.cloudflare.com/ -> Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Entorno
ASPNETCORE_ENVIRONMENT=Production
